# Example Environment Variables for Backend
# Copy this to .env and update with your actual values

# MongoDB Connection
MONGODB_URI=mongodb+srv://your-username:your-password@cluster.mongodb.net/dhansetu?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Gmail Example)
# For Gmail: Enable 2-Step Verification, then create an App Password
# Go to: Google Account > Security > 2-Step Verification > App passwords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password-here

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000

# Backend Port
PORT=5000

# Ganache/Blockchain RPC URL
GANACHE_RPC_URL=http://127.0.0.1:8545

# Deployed Smart Contract Address
CONTRACT_ADDRESS=0xe78A0F7E598Cc8b0Bb87894B0F60dD2a88d6a8Ab

# Private Key (for blockchain transactions - keep secure!)
PRIVATE_KEY=your-private-key-here

# Lender API Key (for lender registration/login)
LENDER_API_KEY=your-secure-lender-api-key

# Node Environment
NODE_ENV=development
