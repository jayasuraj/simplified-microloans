# Backend Environment Variables - Production
# Add these to Render dashboard: Services → Environment Variables
# DO NOT commit this file to git

# Server Configuration
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# MongoDB Atlas - CHANGE THESE
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/dhansetu?retryWrites=true&w=majority

# JWT Secret - CHANGE THIS to a strong random string
JWT_SECRET=your-super-secure-jwt-secret-min-32-characters

# Blockchain Configuration - Already set for Sepolia
PRIVATE_KEY=your_wallet_private_key
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_infura_project_id
ETHERSCAN_API_KEY=your_etherscan_api_key
CONTRACT_ADDRESS=0x43eb6e7886fd677eBb5fFAEf2c688eB04aC8247f
BLOCKCHAIN_NETWORK=sepolia

# Email Service - Gmail SMTP
OTP_EMAIL=your_email@gmail.com
OTP_PASS=your_app_specific_password

# Third-party APIs
FAST2SMS_API_KEY=your_fast2sms_api_key
API_KEY=your_lender_api_key

# KYC Secret
KYC_SECRET=your_kyc_encryption_secret

# Frontend URL - Update after Netlify deployment
FRONTEND_URL=https://your-site-name.netlify.app

# Role-based Configuration
ROLE_API_KEY=your_role_based_api_key
